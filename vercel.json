{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_API_BASE": "https://soul-full-backend.onrender.com/api",
    "NODE_ENV": "production",
    "GENERATE_SOURCEMAP": "false"
  },
  "rewrites": [
    {
      "source": "/:path((?!api).*)*",
      "destination": "/index.html"
    }
  ]
}
